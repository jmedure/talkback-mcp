{
  "name": "talkback-mcp",
  "version": "0.1.5",
  "description": "MCP server giving AI assistants real-time access to Ableton Live sessions",
  "mcpName": "io.github.jmedure/talkback",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmedure/talkback-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "talkback-mcp": "dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/stdio.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/"
  },
  "keywords": [
    "mcp",
    "talkback",
    "ableton",
    "ableton-live",
    "max-for-live",
    "ai",
    "mixing",
    "music-production",
    "claude",
    "model-context-protocol"
  ],
  "license": "PolyForm-Shield-1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
